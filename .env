# Redis settings
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5
REDIS_READ_TIMEOUT=60

# Scanning options
POC_DIR=./poc
DEFAULT_PORTS=top1000
FP_RULES_FILE=./data/fingerprints.json
QUEUE_PREFIX=scan

# Port scan engine settings (naabu)
PORTSCAN_RATE=1000
PORTSCAN_TIMEOUT=5
PORTSCAN_THREADS=25
PORTSCAN_TYPE=connect

# Console Log printing switch (set to false to only write JSON logs to log/log_num.json)
CONSOLE_LOG=true
