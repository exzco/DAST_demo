{
  "http_rules": [
    {
      "tags": ["wordpress", "php"],
      "body": ["wp-content", "wp-includes", "WordPress"]
    },
    {
      "tags": ["spring-boot", "spring", "java"],
      "headers": ["X-Application-Context", "spring"],
      "body": ["Whitelabel Error Page", "Spring Framework", "\"status\":\"UP\""]
    },
    {
      "tags": ["shiro", "java"],
      "headers": ["Set-Cookie: rememberMe="]
    },
    {
      "tags": ["phpmyadmin", "php"],
      "body": ["phpMyAdmin", "phpmyadmin"]
    },
    {
      "tags": ["php"],
      "headers": ["X-Powered-By: PHP"]
    },
    {
      "tags": ["tomcat", "java"],
      "headers": ["Server: Apache-Coyote", "Server: Apache Tomcat"],
      "body": ["Apache Tomcat", "Tomcat"]
    },
    {
      "tags": ["nginx"],
      "headers": ["Server: nginx", "Server: openresty"]
    },
    {
      "tags": ["apache"],
      "headers": ["Server: Apache/"]
    },
    {
      "tags": ["iis", "windows"],
      "headers": ["Server: Microsoft-IIS"]
    },
    {
      "tags": ["drupal", "php"],
      "headers": ["X-Generator: Drupal"],
      "body": ["sites/default/files", "Drupal.settings"]
    },
    {
      "tags": ["joomla", "php"],
      "body": ["/components/com_", "Joomla!"]
    },
    {
      "tags": ["laravel", "php"],
      "headers": ["Set-Cookie: laravel_session"],
      "body": ["Laravel"]
    },
    {
      "tags": ["django", "python"],
      "headers": ["Set-Cookie: csrftoken="],
      "body": ["Django"]
    },
    {
      "tags": ["struts", "java"],
      "headers": ["X-ATG-Version", "Set-Cookie: STRUTS_"],
      "body": ["struts"]
    },
    {
      "tags": ["weblogic", "java"],
      "headers": ["Server: WebLogic"],
      "body": ["WebLogicServer", "BEA WebLogic"]
    },
    {
      "tags": ["jenkins"],
      "headers": ["X-Jenkins"],
      "body": ["Jenkins"]
    },
    {
      "tags": ["grafana"],
      "body": ["grafana", "Grafana"]
    },
    {
      "tags": ["kibana", "elastic"],
      "body": ["kibana", "Kibana"]
    }
  ],
  "banner_rules": [
    {
      "tags": ["redis"],
      "prefix": "+PONG"
    },
    {
      "tags": ["redis"],
      "prefix": "-ERR"
    },
    {
      "tags": ["mysql"],
      "hex_prefix": "4a0000"
    },
    {
      "tags": ["mongodb"],
      "hex_prefix": "3d000000"
    },
    {
      "tags": ["elasticsearch", "elastic"],
      "prefix": "{\"name\""
    },
    {
      "tags": ["memcached"],
      "prefix": "VERSION"
    },
    {
      "tags": ["ftp"],
      "prefix": "220"
    },
    {
      "tags": ["ssh"],
      "prefix": "SSH-"
    },
    {
      "tags": ["smtp"],
      "prefix": "220 "
    },
    {
      "tags": ["rdp"],
      "hex_prefix": "030000"
    },
    {
      "tags": ["zookeeper"],
      "prefix": "Zookeeper"
    }
  ]
}
